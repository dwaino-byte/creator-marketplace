{
  "name": "creator-marketplace",
  "version": "1.0.0",
  "description": "Creator Marketplace Platform - Connect creators with businesses",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:unit": "jest --testPathPattern=__tests__",
    "test:integration": "jest --testPathPattern=__tests__",
    "test:e2e": "cypress run",
    "test:smoke": "cypress run --spec cypress/e2e/smoke.cy.ts",
    "migrate": "node -r ts-node/register scripts/migrate.ts",
    "migrate:prod": "node -r ts-node/register scripts/migrate.ts",
    "seed": "ts-node scripts/seed.ts",
    "seed:prod": "ts-node scripts/seed.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "next": "14.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "@supabase/supabase-js": "^2.38.0",
    "@supabase/auth-helpers-nextjs": "^0.7.0",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^2.4.0",
    "nodemailer": "^6.9.0",
    "axios": "^1.6.0",
    "date-fns": "^2.30.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0",
    "redis": "^4.6.0",
    "jsonwebtoken": "^9.1.0"
  },
  "devDependencies": {
    "typescript": "^5.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/nodemailer": "^6.4.0",
    "@types/jsonwebtoken": "^9.0.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.1.0",
    "@testing-library/jest-dom": "^6.1.0",
    "cypress": "^13.6.0",
    "ts-node": "^10.9.0",
    "eslint": "^8.50.0",
    "eslint-config-next": "14.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
